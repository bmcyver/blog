---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { Awards, CVEs } from "@/consts"
---

<Layout>
  <MetaPage slot="head" />
  <dictionary-entry>
    <h1>bmcyver <ipa-span>/ˈbiː.ɛm.saɪ.vər/</ipa-span></h1>
    <prose-content>
      <p>
        Hello! I'm bmcyver. I'm currently studying
        <strong>web security</strong>. Also, I'm participating in CTFs as a
        member of the
        <strong
          ><a
            href="https://deadsec.team"
            target="_blank"
            rel="noopener noreferrer"
            >DeadSec</a
          ></strong
        >.
      </p>
      <p>
        I also enjoy playing <strong>Genshin Impact</strong> in my free time.
      </p>

      <sub>//TODO: 블로그 디자인....! 다시 하기 :)</sub>

      <h3>Awards</h3>
      <table class="awards-table">
        <tbody>
          {Awards.map((award) => (
              <tr>
                <td>{award.year}</td>
                <td>{award.event}</td>
                <td>{award.team}</td>
                <td>
                  <strong>{award.place}</strong>
                </td>
              </tr>
            ))}
        </tbody>
      </table>

      <h3>CVEs</h3>
      <ul>
        {CVEs.map((cve) => (
            <li>
              <a
                href={`https://nvd.nist.gov/vuln/detail/${cve}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {cve}
              </a>
            </li>
          ))}
      </ul>
    </prose-content>
  </dictionary-entry>
</Layout>

<style>
  .awards-table {
    display: table;
    width: 100%;
    max-inline-size: 100%;
    margin-inline: 0;
    font-size: var(--step-0);
  }

  .awards-table :is(th, td) {
    min-width: unset;
    padding-inline: 0.5rem;
    color: var(--prose-foreground);
    line-height: calc(var(--leading-offset) + 1em);
  }

  .awards-table td:first-child {
    padding-inline-start: 0;
  }

  .awards-table td:last-child {
    padding-inline-end: 0;
    text-align: end;
  }

  dictionary-entry {
    display: block;
    font-size: var(--step-0);
    color: var(--muted-foreground);

    @media (width >= 64rem) {
      margin-block-start: -0.2em;
    }

    ipa-span {
      font-size: var(--step--1);
      font-weight: var(--font-weight-normal);
      opacity: 0.6;
      margin-inline-start: 0.5rem;
      vertical-align: middle;
    }

    h1 {
      font-size: var(--step-2);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
      color: var(--foreground);
      margin-block-end: var(--space-2xs);
    }

    ol {
      margin-block-start: var(--space-xs);
      list-style: none;

      li {
        padding-inline-start: 1em;
        text-indent: -1em;

        &::before {
          content: counter(list-item);
          display: inline-block;
          inline-size: 1em;
          text-indent: 0;
          font-weight: var(--font-weight-medium);
        }

        + li {
          margin-block-start: var(--space-3xs);
        }
      }
    }

    hr {
      margin-block: var(--space-m);
      border-block-start: 2px solid var(--border);
    }

    prose-content {
      margin-block-start: var(--space-xs);
    }
  }
</style>
